rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /sections/{sectionId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }
    match /pages/{pageId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null && isSuperAdmin();
    }
    match /admins/{docId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if request.auth != null && isSuperAdmin();
    }

    // Service schedule
    match /serviceEvents/{dateId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }
    match /serviceTemplates/{templateId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }
    match /serviceEntryTypes/{entryId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // Sunday School
    match /ssEvents/{dateId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }
    match /ssTemplates/{templateId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }
    match /ssEntryTypes/{entryId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // Temporary test document — REMOVE before go-live
    match /_test/{docId} {
      allow read, write: if true;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isSuperAdmin() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'superadmin';
    }
  }
}
